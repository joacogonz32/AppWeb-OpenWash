rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario — FR-006, FR-007, FR-023.
    // Cada usuario lee/escribe su propio documento; admin lee todos.
    match /usuarios/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "admin");
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "admin");
      allow delete: if request.auth != null &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "admin");
    }

    // Turnos — FR-014 a FR-022.
    // Los turnos son creados/cancelados por Cloud Functions (crearTurno, cancelarTurno).
    // Los clientes solo leen sus propios turnos; admin lee todos.
    match /turnos/{turnoId} {
      allow read: if request.auth != null &&
        (resource.data.usuarioUid == request.auth.uid ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == "admin");
      // Escritura solo via Admin SDK (Cloud Functions); clientes NO escriben directamente.
      allow write: if false;
    }

    // Disponibilidad en tiempo real — FR-013.
    // Solo Cloud Functions via Admin SDK pueden escribir (REQ-GAP-01 resuelto).
    // Ver data-model.md seccion 2.
    match /disponibilidad/{fecha}/slots/{horario} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Cualquier otra coleccion: denegada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
